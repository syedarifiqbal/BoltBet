# ─────────────────────────────────────────────────────────────────────────────
# BoltBet — Environment Variables
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For environment-specific overrides:
#   .env.development  — loaded first in NODE_ENV=development
#   .env.production   — loaded first in NODE_ENV=production (never commit this)
#   .env.test         — loaded first in NODE_ENV=test
#
# Loading order: .env.{NODE_ENV} takes precedence over .env.
# Variables already set in the shell environment take precedence over both.
#
# All variables listed here are validated at startup by src/config/env.validation.ts.
# The app will refuse to start if a required variable is missing or has wrong type.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
# amqp:// for local, amqps:// for TLS connections (production)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Postgres — Phase 1 ─────────────────────────────────────────────────────────
# Writes go through PgBouncer (port 6432). Reads go direct to replica (port 5433).
DATABASE_URL=postgresql://boltbet:secret@localhost:6432/boltbet
DATABASE_READ_URL=postgresql://boltbet:secret@localhost:5433/boltbet

# ── Redis — Phase 1 ────────────────────────────────────────────────────────────
# Persistent instance: idempotency keys, JWT blacklist, circuit breaker state
REDIS_URL=redis://localhost:6379
# Ephemeral instance: rate limit counters, odds cache (loss on restart is acceptable)
REDIS_EPHEMERAL_URL=redis://localhost:6380

# ── JWT / Auth — Phase 2 ───────────────────────────────────────────────────────
# RS256 asymmetric keys. Generate with:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# In production: mount as Docker secrets or set via secrets manager.
# The value is the full PEM string with newlines replaced by \n:
#   JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# JWT_ACCESS_TTL=900        # seconds — 15 minutes
# JWT_REFRESH_TTL=604800    # seconds — 7 days

# ── Password security — Phase 2 ────────────────────────────────────────────────
# Minimum 32 bytes of random data. Generate with: openssl rand -hex 32
# PASSWORD_PEPPER=
# TOTP_ENCRYPTION_KEY=      # Exactly 32 bytes for AES-256
# HIBP_API_KEY=
